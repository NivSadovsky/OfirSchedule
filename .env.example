# PostgreSQL connection string (provided by Railway)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Google OAuth 2.0 credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Express session secret (any long random string)
SESSION_SECRET=change-this-to-a-long-random-secret

# The Google email that gets lecturer role
LECTURER_EMAIL=lecturer@example.com

# Gmail SMTP credentials (use App Password, not account password)
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Public URL of the deployed app (for OAuth redirect URI)
BASE_URL=https://your-app.railway.app

# Set to "production" on Railway
NODE_ENV=production
